msgstr "Réglages du distributeur à boules"

#. parameter name
#: boxes/generators/fatballdispenser.py
msgid "sides"
msgstr "côtés"

#. help for parameter sides
#: boxes/generators/fatballdispenser.py
msgid "The number of sides of the floor plan."
msgstr "Le nombre de côtés du plan (vu du dessus)."

#. parameter name
#: boxes/generators/fatballdispenser.py
msgid "pole_diameter"
msgstr "diamètre des montants"

#. help for parameter pole_diameter
#: boxes/generators/fatballdispenser.py
msgid "The diameter of the poles."
msgstr "Le diamètre des montants en mm."

#. parameter name
#: boxes/generators/fatballdispenser.py
msgid "ball_diameter"
msgstr "diamètre des boules"

#. help for parameter ball_diameter
#: boxes/generators/fatballdispenser.py
msgid ""
"The diameter of the fat balls. Give some extra mm to make it a loose fit"
msgstr ""
"Le diamètre des boules de graisse en mm. Prévoir quelques mm de plus pour un"
" ajustement souple."

#. parameter name
#: boxes/generators/fatballdispenser.py
msgid "balcony_width"
msgstr "largeur du balcon"

#. help for parameter balcony_width
#: boxes/generators/fatballdispenser.py
msgid "The width of the area outside of the poles."
msgstr "La largeur du balcon (zone à l'extérieur des montants) en mm."

#. parameter name
#: boxes/generators/fatballdispenser.py
msgid "balcony_height"
msgstr "hauteur du balcon"

#. help for parameter balcony_height
#: boxes/generators/fatballdispenser.py
msgid "The height of the balcony in mm. Set to 0 if no walls are needed."
msgstr ""
"La hauteur du balcon en mm. Mettre 0 si aucune paroi n'est nécessaire."

#. parameter name
#: boxes/generators/fatballdispenser.py
msgid "drain_hole_diameter"
msgstr "diamètre du trou d'évacuation"

#. help for parameter drain_hole_diameter
#: boxes/generators/fatballdispenser.py
msgid ""
"The diameter of the hole of the floor (to drain rainwater)\n"
"                    in mm. Set to 0 if you don't need it."
msgstr ""
"Le diamètre du trou dans le fond (pour évacuer l'eau de pluie) en mm. Mettre"
" 0 pour ne pas percer de trou."

#. parameter name
#: boxes/generators/fatballdispenser.py
msgid "pole_clearance"
msgstr "dégagement des montants"

#. help for parameter pole_clearance
#: boxes/generators/fatballdispenser.py
msgid ""
"The minimum distance between a pole and the central\n"
"                    refill hole in the ceiling in mm."
msgstr ""
"La distance minimale entre un montant et l'ouverture centrale de remplissage"
" dans la plaque supérieure, en mm."

#. parameter name
#: boxes/generators/fatballdispenser.py
msgid "slide_clearance"
msgstr "jeu du verrouillage"

#. help for parameter slide_clearance
#: boxes/generators/fatballdispenser.py
msgid ""
"The gap between the parts that slide into each other\n"
"                    in the locking mechanism in mm."
msgstr ""
"Le jeu horizontal entre les pièces du mécanisme de verrouillage qui glissent"
" l'une dans l'autre, en mm."

#. parameter name
#: boxes/generators/fatballdispenser.py
