msgid "DefaultParams Settings"
msgstr "Réglages des paramètres par défaut"

#. parameter name
msgid "x"
msgstr "x"

#. help for parameter x
msgid "inner width in mm (unless outside selected)"
msgstr "largeur interieure en mm (si on ne choisit pas « extérieur »)"

