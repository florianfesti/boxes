msgid "county"
msgstr "comté"

#. help for parameter county
#: boxes/generators/gridfinitytraylayout.py
msgid "split y into this many grid sections.  0 means same as --ny"
msgstr ""
"divisez y en autant de sections de grille.  0 signifie la même chose que "
"--ny"

